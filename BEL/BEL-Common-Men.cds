SYNTH MEN-ACWY-CONJ "MEN-ACWY- At least one dose of ACWY conjugate vaccine" IS ANY OF
  HIST(Men,0,vaccine) contains VAC0486 # NIMENRIX      # To be checked, Men is not a parent to MenA,MenB ...
  HIST(Men,0,vaccine) contains VAC0141 # MENVEO
  HIST(Men,0,vaccine) contains VAC0594 # MenQuadfi
  HIST(Men,0,vaccine) contains VAC0103# MENACTRA
  